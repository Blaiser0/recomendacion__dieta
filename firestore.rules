rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Registro de consultas (diagnóstico + dieta). Sustituye por reglas con Auth en producción.
    match /registros_consulta/{id} {
      allow read, write: if request.time < timestamp.date(2027, 6, 1);
    }
  }
}

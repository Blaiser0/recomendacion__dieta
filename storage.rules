rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Foto de perfil: `perfiles/{uid}.jpg` (solo el propio usuario, < 6 MB).
    // Sin filtro por contentType: la galería puede enviar JPEG, PNG o HEIC.
    match /perfiles/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName == request.auth.uid + '.jpg'
        && request.resource.size < 6 * 1024 * 1024;
    }
  }
}
